FROM node:22-alpine AS builder
WORKDIR /app

COPY package.json package-lock.json ./
COPY packages/types/package.json packages/types/
COPY apps/dashboard/package.json apps/dashboard/

RUN npm ci

COPY tsconfig.base.json ./
COPY packages/types packages/types/
COPY apps/dashboard apps/dashboard/

ARG VITE_ORCHESTRATOR_URL=http://localhost:3000
ARG VITE_AGENT_REGISTRY_ADDRESS=0xC1476f6Dfc8C3f6593B21FDab8DA156e9Be274B1
ARG VITE_AEGIS_NAME_REGISTRY_ADDRESS=0xC8e1B8763be717Daee9b41CFD68F723f6bA06aC4
ARG VITE_PUBLIC_RESOLVER_ADDRESS=0x231b0Ee14048e9dCcD1d247744d114a4EB5E8E63
ARG VITE_AEGIS_COURT_ADDRESS=0xA35Ec64578EF4C85a88fE19A81a4303a784B9dd6
ARG VITE_0G_EXPLORER_URL=https://chainscan-galileo.0g.ai
ARG VITE_KEEPERHUB_WORKFLOW_ID=aegis.execute_remedy

ENV VITE_ORCHESTRATOR_URL=$VITE_ORCHESTRATOR_URL
ENV VITE_AGENT_REGISTRY_ADDRESS=$VITE_AGENT_REGISTRY_ADDRESS
ENV VITE_AEGIS_NAME_REGISTRY_ADDRESS=$VITE_AEGIS_NAME_REGISTRY_ADDRESS
ENV VITE_PUBLIC_RESOLVER_ADDRESS=$VITE_PUBLIC_RESOLVER_ADDRESS
ENV VITE_AEGIS_COURT_ADDRESS=$VITE_AEGIS_COURT_ADDRESS
ENV VITE_0G_EXPLORER_URL=$VITE_0G_EXPLORER_URL
ENV VITE_KEEPERHUB_WORKFLOW_ID=$VITE_KEEPERHUB_WORKFLOW_ID

WORKDIR /app/apps/dashboard
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/apps/dashboard/dist /usr/share/nginx/html
COPY apps/dashboard/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 4000
CMD ["nginx", "-g", "daemon off;"]
